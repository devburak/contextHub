{
  "name": "contexthub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "description": "Multi\u2011tenant headless CMS and content services platform.",
  "license": "MIT",
  "scripts": {
     "start": "NODE_ENV=production node src/server.js",
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@contexthub/api",
    "dev:admin": "turbo dev --filter=@contexthub/admin",
    "dev:parallel": "turbo dev --parallel",
    "build": "turbo build",
    "build:api": "turbo build --filter=@contexthub/api",
    "build:admin": "turbo build --filter=@contexthub/admin",
    "deploy": "pnpm build:admin && node scripts/deploy-admin.mjs",
    "deploy:admin": "node scripts/deploy-admin.mjs",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "turbo format",
    "format:check": "turbo format -- --check",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "create:index": "node scripts/create-indexes.mjs",
    "db:seed": "turbo dev --filter=@contexthub/api -- --seed",
    "db:migrate": "turbo dev --filter=@contexthub/api -- --migrate",
    "dispatch:webhooks": "node apps/api/scripts/dispatch-webhooks.js",
    "cron:webhooks": "node apps/api/scripts/webhook-cron.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.13.1 <25"
  },
  "devDependencies": {
    "turbo": "^2.8.13",
    "dotenv": "^16.6.1",
    "node-ssh": "^13.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.8.1",
    "vitest": "^0.34.6"
  }
}
