{
  "name": "@contexthub/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify back‑end service for contextHub",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "dev:watch": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo \"API build completed - production ready\"",
    "test": "node ../../scripts/run-tool.mjs vitest run --dir src",
    "test:watch": "node ../../scripts/run-tool.mjs vitest --dir src",
    "lint": "node ../../scripts/run-tool.mjs eslint . --ext .js,.ts",
    "lint:fix": "node ../../scripts/run-tool.mjs eslint . --ext .js,.ts --fix",
    "format": "node ../../scripts/run-tool.mjs prettier --write .",
    "format:check": "node ../../scripts/run-tool.mjs prettier --check .",
    "clean": "rm -rf dist .turbo",
    "type-check": "echo \"No TypeScript in API yet\"",
    "db:seed": "node scripts/seed.js",
    "db:bootstrap": "node src/scripts/bootstrapCore.js",
    "db:migrate": "node scripts/migrate.js",
    "db:backfill-subscriptions": "node src/scripts/backfillTenantSubscriptions.js",
    "db:seed-plans": "node src/scripts/seedSubscriptionPlans.js",
    "db:seed-flags": "node src/scripts/seedFeatureFlags.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/s3-request-presigner": "^3.1001.0",
    "@contexthub/common": "workspace:*",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^7.2.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.3",
    "marked": "^16.4.2",
    "nodemailer": "^6.10.1",
    "redis": "^5.11.0",
    "sharp": "^0.33.2",
    "undici": "^6.23.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
